# 로컬 개발용 — copy .env.example .env 후 값 수정
# 배포: 호스트 대시보드에 아래 변수를 각각 한 번만 등록 (중복 키 불가)

# 로컬 전용 (배포 시 호스트가 PORT/NODE_ENV를 자동 설정하는 경우 생략 가능)
PORT=3000

# 프런트 origin (쉼표로 여러 개 가능)
# 로컬: http://localhost:5173
# 배포: https://your-frontend.example.com,http://localhost:5173
CORS_ORIGIN=http://localhost:5173

# PostgreSQL (배포 DB URL — Render는 대시보드에서 복사)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/cozy

# 로컬에서 SSL 끄기: DATABASE_SSL=false
# 관리형 DB 강제 인식: DATABASE_MANAGED=true
