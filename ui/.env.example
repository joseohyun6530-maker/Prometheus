# 로컬 npm run dev — .env.development 가 /api/v1 + Vite 프록시 사용 (CORS 회피)
# 로컬에서 server 를 직접 띄울 때: ui/.env.development 를 http://localhost:3000/api/v1 로 변경

# 프로덕션 빌드(Render Static Site 등)
VITE_API_BASE_URL=https://prometheus-2qjs.onrender.com/api/v1

# 로컬 프록시 대상 변경 시 (선택)
# VITE_DEV_API_PROXY=http://localhost:3000
